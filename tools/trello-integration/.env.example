# Composio credentials used ONLY to generate the Trello MCP URL.
# Copy this file to `.env` (which is gitignored) and fill in real values.
# Never commit real keys.

# From https://dashboard.composio.dev  (Settings → API Keys)
COMPOSIO_API_KEY=your_composio_api_key_here

# Any stable identifier for the connected user — your email or e.g. "default".
# This is the Composio "entity" the Trello account gets linked to.
USER_ID=your_user_id_here
